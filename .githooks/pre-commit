#!/bin/bash
# Pre-commit hook: block commits containing personal/sensitive patterns.
# Patterns are read from .githooks/sensitive-patterns.txt (gitignored).
# To install: run `git config core.hooksPath .githooks` in the repo root.

PATTERNS_FILE=".githooks/sensitive-patterns.txt"

if [ ! -f "$PATTERNS_FILE" ]; then
  echo "WARNING: $PATTERNS_FILE not found."
  echo "Copy .githooks/sensitive-patterns.example.txt to .githooks/sensitive-patterns.txt"
  echo "and add the terms you want to block. Proceeding without pattern check..."
  exit 0
fi

# Get the staged diff, excluding files that legitimately reference path patterns
# (the sanitizer script itself, and the hook tooling). These files MUST contain
# the patterns they operate on — excluding them prevents a self-block loop.
STAGED_DIFF=$(git diff --cached -- . ':!sync-from-live.sh' ':!.githooks/pre-commit' ':!.githooks/sensitive-patterns.example.txt')

if [ -z "$STAGED_DIFF" ]; then
  # No staged changes — nothing to check
  exit 0
fi

MATCHED=0
MATCHES=""

while IFS= read -r pattern; do
  # Skip blank lines and comment lines
  if [ -z "$pattern" ] || [ "${pattern:0:1}" = "#" ]; then
    continue
  fi

  # Check staged diff for pattern (case-insensitive, fixed-string)
  if echo "$STAGED_DIFF" | grep -iqF -- "$pattern"; then
    MATCHES="$MATCHES  - $pattern"$'\n'
    MATCHED=1
  fi
done < "$PATTERNS_FILE"

if [ $MATCHED -eq 1 ]; then
  echo ""
  echo "=========================================================="
  echo "COMMIT BLOCKED: sensitive patterns detected in staged diff"
  echo "=========================================================="
  echo ""
  echo "Matched patterns:"
  echo "$MATCHES"
  echo "Review your staged changes with: git diff --cached"
  echo "Remove the sensitive content, re-stage, and commit again."
  echo ""
  echo "To bypass (not recommended): git commit --no-verify"
  echo ""
  exit 1
fi

exit 0
